# Copy this to .env.local for local dev — NEVER commit .env.local to GitHub
# Add ALL of these in Vercel → Project → Settings → Environment Variables

# ── Supabase (supabase.com → your project → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Anthropic (console.anthropic.com → API Keys)
# Server-side only — NEVER use VITE_ prefix for secret keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google Civic Information API (FREE — 25,000 queries/day)
# How to get:
#   1. Go to console.cloud.google.com
#   2. Create a new project (or use existing)
#   3. Go to APIs & Services → Library
#   4. Search "Civic Information API" → Enable it
#   5. Go to APIs & Services → Credentials → Create API Key
#   6. Copy the key here
# Covers: voterInfoQuery (polling places, early voting, ballot candidates)
#         elections list (active election IDs)
# Docs: https://developers.google.com/civic-information
# Server-side only — NEVER use VITE_ prefix
GOOGLE_CIVIC_API_KEY=your-google-key-here

# ── OpenStates / Plural API (FREE for civic use)
# How to get:
#   1. Go to open.pluralpolicy.com
#   2. Register for a free account
#   3. Go to your profile → API Keys → Create Key
#   4. Copy the key here
# Covers: Georgia state legislators, party affiliation, districts, voting records
# Note: OpenStates is now managed by Plural Policy — same data, new home
# Docs: https://docs.openstates.org/api-v3/
# Server-side only — NEVER use VITE_ prefix
OPENSTATES_API_KEY=your-openstates-key-here

# ── Security
# Set this to your Vercel deployment URL after first deploy
ALLOWED_ORIGIN=https://your-project.vercel.app


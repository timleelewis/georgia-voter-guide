# Copy this to .env.local for local dev — NEVER commit .env.local to GitHub
# Add all of these to Vercel → Project → Settings → Environment Variables

# ── Supabase (supabase.com → your project → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Anthropic (console.anthropic.com → API Keys)
# Server-side only — never use VITE_ prefix for this one
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google Civic Information API (FREE)
# How to get: console.cloud.google.com → New Project → Enable "Civic Information API" → Create API Key
# Docs: https://developers.google.com/civic-information
# Server-side only — never use VITE_ prefix
GOOGLE_CIVIC_API_KEY=your-google-key-here

# ── Democracy Works Elections API (FREE for nonprofits/civic tools)
# How to get: email partnerships@democracy.works — mention your civic voter guide project
# Docs: https://developers.democracy.works/api/v2
# Server-side only — never use VITE_ prefix
DEMOCRACY_WORKS_API_KEY=your-dw-key-here

# ── Security
ALLOWED_ORIGIN=https://your-project.vercel.app
